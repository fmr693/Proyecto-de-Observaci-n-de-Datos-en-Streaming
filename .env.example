# ============================================
# CONFIGURACIÓN — PRÁCTICA IoT (Wokwi → Kafka → Spark → MinIO)
# Copia este archivo a .env y personaliza MQTT_TOPIC
# ============================================

# --- Puertos ---
KAFKA_PORT=29092
KAFKA_UI_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- MinIO ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123

# --- Kafka ---
KAFKA_TOPIC=iot-sensor

# --- MQTT (broker público HiveMQ) ---
# El ESP32 simulado en Wokwi publica aquí, y el bridge se suscribe.
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
# ⚠️ El broker es PÚBLICO y compartido: usa un topic único tuyo
# (el mismo que pongas en el sketch de Wokwi)
MQTT_TOPIC=iabd/TU-USUARIO/iot-sensor
